# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/governance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=governance

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── ElasticSearch ───────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_LEGAL=legal_sections
ELASTICSEARCH_INDEX_AUDIT=audit_logs

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=ecosphere_governance_dev_secret_64_chars_minimum_change_in_prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── AI / LLM ────────────────────────────────────────────────────────────────
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=EcoSphere Governance
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─── Government Data Connectors ──────────────────────────────────────────────
CONNECTOR_SYNC_INTERVAL_HOURS=24
INDIA_CODE_BASE_URL=https://www.indiacode.nic.in
MCA_BASE_URL=https://www.mca.gov.in
LABOUR_BASE_URL=https://labour.gov.in
SHRAM_SUVIDHA_BASE_URL=https://registration.shramsuvidha.gov.in
INDIA_GOV_BASE_URL=https://www.india.gov.in

# ─── Email / Notifications ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=governance@ecosphere.in

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Audit ────────────────────────────────────────────────────────────────────
AUDIT_SIGNATURE_SECRET=ecosphere_audit_dev_secret_64_chars_minimum_change_in_prod
